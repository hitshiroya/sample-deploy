# Copy this file to backend-secret.yml and fill in base64-encoded value
# Generate base64: echo -n "postgresql://user:pass@notes-postgres:5432/notesdb" | base64
#
# backend-secret.yml is gitignored — never commit real credentials

apiVersion: v1
kind: Secret
metadata:
  name: backend-secret
  namespace: notes-app
type: Opaque
data:
  DATABASE_URL: <base64-encoded-database-url>
