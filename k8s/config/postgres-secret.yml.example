# Copy this file to postgres-secret.yml and fill in base64-encoded values
# Generate base64: echo -n "your-value" | base64
#
# postgres-secret.yml is gitignored — never commit real credentials

apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: notes-app
type: Opaque
data:
  POSTGRESQL_USERNAME: <base64-encoded-username>
  POSTGRESQL_PASSWORD: <base64-encoded-password>
